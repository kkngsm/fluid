    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "Debug unit tests in library 'fluid_euler'",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "test"
                ]
            }
        },
        {
            "name": "Debug executable 'fluid_euler_run'",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "run",
                    "--bin=fluid_euler_run"
                ]
            },
            "args": []
        },
        {
            "name": "Debug executable 'fluid_euler_run' (no gui)",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "run",
                    "--bin=fluid_euler_run",
                    "--no-default-features"
                ]
            },
            "args": []
        },
        {
            "name": "Debug unit tests in executable 'fluid_euler_run'",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "test",
                    "--bin=fluid_euler_run"
                ]
            }
        }
    ]
}